{
  "ServiceConfiguration": {
    "ServiceName": "HIDSecurityService",
    "Logging": {
      "LogPath": "logs",
      "EventLogSource": "HIDSecurityService",
      "MinimumLogLevel": "Information",
      "RetentionDays": 90,
      "MaxFileSizeMb": 100,
      "EnableEventLog": true,
      "EnableFileLog": true
    },
    "Monitoring": {
      "PollingIntervalMs": 2000,
      "EnableDeviceTracking": true,
      "EnableBehaviorAnalysis": true,
      "MaxTrackedDevices": 1000,
      "DeviceHistoryRetention": "30.00:00:00"
    },
    "Policy": {
      "PolicyPath": "policies",
      "ActivePolicyId": "default",
      "AutoReloadOnchange": true,
      "ReloadIntervalSeconds": 60
    },
    "Ipc": {
      "PipeName": "HIDSecurityService",
      "EnableEncryption": true,
      "AllowedUsers": [],
      "AllowedGroups": [
        "BUILTIN\\Administrators",
        "NT AUTHORITY\\SYSTEM"
      ],
      "MaxConnections": 10,
      "ConnectionTimeout": "00:00:30"
    },
    "Security": {
      "EnableIntegrityChecks": true,
      "IntegrityKeyPath": "security\\integrity.key",
      "EnableDpapiEncryption": true,
      "DpapiScope": "LocalMachine",
      "ProtectedPaths": [
        "policies",
        "data",
        "logs"
      ]
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
    }
    }
  },
  "AllowedHosts": "*"
}
